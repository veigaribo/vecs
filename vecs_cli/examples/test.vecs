// set default_component_max 220;

component transform {
  double x;
  double y;
};

component render {
  int texture;
};

event mouse_click {
  double x;
  double y;
  uint8_t button;
};

system move on mouse_click { transform };
system render { transform; render };

state main {
  components {
    transform;
    render;
  };

  systems {
    { move };
    { render };
  };
};
